{
  "buildCommand": "echo 'Static frontend + Python API'",
  "outputDirectory": "frontend",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/api/$1" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ],
  "functions": {
    "backend/api/index.py": {
      "runtime": "python3.12",
      "maxDuration": 30
    }
  }
}
